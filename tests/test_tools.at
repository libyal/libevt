m4_include([package.m4])
m4_include([test_macros.at])

include_test_inputs([evtexport])
include_test_inputs([evtinfo])

AT_TEST_HELPER_FN(
  [run_evttools_binary],
  [path arguments],
  [Resolves and runs a evttools binary],
  [if test -x "$abs_top_builddir/evttools/$[]1"; then
    BINARY="$abs_top_builddir/evttools/$[]1"
  elif test -x "$abs_top_builddir/evttools/$[]1.exe"; then
    # Prevent wine debug messages failing the test.
    export WINEDEBUG=-all

    BINARY="$abs_top_builddir/evttools/$[]1.exe"
  else
    echo "Missing binary: $[]1"
    exit 127
  fi
  shift

  $BINARY $[]*
  ])

AT_TEST_HELPER_FN(
  [run_evttools_binary_with_reference_output],
  [tool_name arguments test_file],
  [Runs a evttools binary and compares its output against a reference],
  [EVTTOOL="$[]1"

  shift
  for TEST_FILE do :; done
   
  FILENAME=`basename "${TEST_FILE}"`
  TEST_SET=`dirname "${TEST_FILE}"`
  TEST_SET=`basename "${TEST_SET}"`
  OUTPUT_FILE="${FILENAME}.log"

  ath_fn_run_evttools_binary "${EVTTOOL}" $[]* > "${OUTPUT_FILE}"
  STATUS=$?

  if test ${STATUS} -eq 0; then
    # Strip header with version.
    ${SED} -i'~' '1,2d' "${OUTPUT_FILE}"

    EXPECTED_RESULTS="$abs_srcdir/input/.${EVTTOOL}/${TEST_SET}/${FILENAME}.gz"
    if test -f "${EXPECTED_RESULTS}"; then
      # zcat on Mac OS requires the input from stdin.
      ${ZCAT} < "${EXPECTED_RESULTS}" | diff "${OUTPUT_FILE}" -;
      STATUS=$?
    else
      ${GZIP_COMMAND} "${OUTPUT_FILE}"
      mkdir -p "${EXPECTED_RESULTS}"
      mv "${OUTPUT_FILE}.gz" "${EXPECTED_RESULTS}"
    fi
  fi
  exit $STATUS
  ])

dnl Runs a evttool and compares its output against a reference
dnl Arguments:
dnl   tool_name
dnl   test_inputs
m4_define([RUN_TEST_EVTTOOL],
  [m4_foreach_w(
    [test_input],
    [$2],
    [m4_define([option_set], m4_normalize(get_test_result_value([test_input], 1)))
    m4_define([test_options], m4_normalize(get_test_result_value([test_input], 2)))
    m4_define([test_file], m4_normalize(get_test_result_value([test_input], 3)))

    m4_define([sanitized_test_file],
      [m4_translit([test_file], [[],[],[]"'`\], [______])])

    m4_ifblank(
      test_options,
      [AT_SETUP($1 with input: 'sanitized_test_file')

      AT_SKIP_IF(
        [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

      AT_SKIP_IF([test -z "${GZIP_COMMAND}"])
      AT_SKIP_IF([test -z "${SED}"])
      AT_SKIP_IF([test -z "${ZCAT}"])

      TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/test_file"`

      AT_CHECK(ath_fn_run_evttools_binary_with_reference_output $1 "${TEST_FILE}")

      AT_CLEANUP],
      [AT_SETUP($1 with options: 'test_options' and input: 'sanitized_test_file')

      AT_SKIP_IF(
        [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

      AT_SKIP_IF([test -z "${GZIP_COMMAND}"])
      AT_SKIP_IF([test -z "${SED}"])
      AT_SKIP_IF([test -z "${ZCAT}"])

      TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/test_file"`

      AT_CHECK(ath_fn_run_evttools_binary_with_reference_output $1 test_options "${TEST_FILE}")

      AT_CLEANUP])]
    )]
  )]
)

dnl Wrap m4_define to overwrite AT_TESTSUITE_NAME
m4_define([_M4_DEFINE_HOOK], m4_defn([m4_define]))
m4_define([m4_define],
  [m4_if(
    [$1],
    [AT_TESTSUITE_NAME],
    [_M4_DEFINE_HOOK([$1], [Running tools tests])],
    [_M4_DEFINE_HOOK([$1], [$2])])])

dnl Redefine AS_BOX to remove the "box"
m4_undefine([AS_BOX])
m4_define([AS_BOX], [echo "$1"])

AT_INIT([tools])
AT_COLOR_TESTS

dnl Rewrite AT_SETUP to change the minimum line length
m4_define([AT_SETUP],
  m4_unquote(
    [m4_bpatsubst(
      m4_dquote(m4_defn([AT_SETUP])),
      [47],
      [72])
    ])
  )

SETUP_HELPER_FUNCTIONS

RUN_TEST_BINARIES(
  [SKIP_TOOLS_TESTS],
  [tools_info_handle tools_message_handle tools_message_string tools_output tools_path_handle tools_registry_file tools_resource_file tools_signal])

RUN_TEST_EVTTOOL(
  [evtinfo],
  test_inputs_evtinfo)

RUN_TEST_EVTTOOL(
  [evtexport],
  test_inputs_evtexport)
